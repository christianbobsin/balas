# Copy this file to ".balas.env" in the repo root and adjust only the values
# that differ on your machine. Existing environment variables always override
# this file.

# Serial device used by automator/profiler.
# BALAS_SERIAL_PORT=/dev/ttyACM0

# Optional: absolute path to stm32tflm. If omitted, the scripts try:
# 1. "stm32tflm" from PATH
# 2. common ST install locations under $HOME
# BALAS_STM32TFLM_BIN=$HOME/opt/st/x-cube-ai/10.2.0/stedgeai-linux-10.2.0/Utilities/linux/stm32tflm

# Optional: MCUXpresso IDE binary. Default is the usual Linux install path.
# MCUXPRESSO_IDE_BIN=/usr/local/mcuxpressoide/ide/mcuxpressoide

# Optional: workspace directory for the MCUXpresso headless build.
# Default: <repo>/cpp-project
# MCUX_WORKSPACE_DIR=$PWD/cpp-project

# Optional: automatically import the project before the headless build.
# Default: 1
# MCUX_IMPORT_PROJECT=1

# Optional: build configuration used by compile.sh.
# Default: Debug
# BUILD_CONFIG=Debug

# Optional: LinkServer root used by deploy.sh.
# Default: /usr/local/LinkServer
# LINKSERVER_ROOT=/usr/local/LinkServer

# Optional: probe serial for deploy.sh.
# PROBE_SERIAL=
